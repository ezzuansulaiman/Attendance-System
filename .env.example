SERVICE_MODE=web

# Flask web app
FLASK_SECRET_KEY=tukar-kepada-nilai-rawak-panjang
FLASK_DEBUG=0
PORT=8080
SESSION_COOKIE_SECURE=1

# Admin first-run password.
# Wajib isi nilai sebenar untuk deployment.
ADMIN_PASSWORD=

# Database
# Railway production recommendation: gunakan PostgreSQL service dan set DATABASE_URL.
# Leave blank untuk local SQLite sahaja.
DATABASE_URL=
SQLITE_PATH=attendance.db

# Telegram Bot
# Digunakan juga oleh web app untuk hantar/simpan bukti sokongan terus ke Telegram.
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
ADMIN_TELEGRAM_IDS=123456789,987654321
ADMIN_TELEGRAM_GROUP_IDS=-1001234567890
BOT_TIMEZONE=Asia/Kuala_Lumpur
WORKDAY_START=07:00
WORKDAY_END=17:30
